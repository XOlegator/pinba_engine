{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PINBA_WITH_TESTS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug with sanitizers",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PINBA_DEBUG": "ON",
        "PINBA_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "release-download-mysql-source",
      "displayName": "Release with downloaded MySQL source headers",
      "inherits": "release",
      "cacheVariables": {
        "PINBA_DOWNLOAD_MYSQL_SOURCE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    }
  ],
  "testPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
