# Local editor and agent files
.codex
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~

# Python/tooling environments
.venv/
.pre-commit-cache/

# CMake build trees and generated files
build/
build-*/
cmake-build-*/
out/
_deps/
CMakeUserPresets.json
compile_commands.json

# Build outputs
*.a
*.so
*.o
*.lo
*.la
*.d
# *.d would normally match conf.d directories; keep docker/ tracked
!docker/
!docker/**

# Test, coverage, and benchmark outputs
Testing/
test_results/
benchmark_results/
*.gcda
*.gcno
*.profraw
*.profdata
coverage-*.info
*.xml
!debian/*.metainfo.xml
*.json
!CMakePresets.json
!.release-please-manifest.json
!release-please-config.json
!.github/mysql-versions.json
!.github/rpm-matrix.json

# Generated documentation
docs/api/

# Personal/local documentation (not for public repo)
docs/docker.personal.md

# Logs and temporary files
*.log
*.tmp
*.temp

# Generated local configuration
config.h
src/config.h

# Debian packaging build artifacts
debian/build-mysql80/
debian/build-mysql84/
debian/tmp-mysql80/
debian/tmp-mysql84/
debian/pinba-engine-mysql-8.0/
debian/pinba-engine-mysql-8.4/
debian/pinba-engine-common/
debian/files
debian/debhelper-build-stamp
debian/*.substvars
debian/*.log
debian/.debhelper/
debian/pinba-ppa-build.mk

# MySQL source tarballs used by tools/extract-mysql-headers.sh (not committed)
vendor/*.tar.gz

# CMake-generated files inside vendor/mysql-headers-* (written to
# PINBA_MYSQL_SOURCE_DIR/builddir/ during cmake configure; reproducible)
vendor/*/builddir/
# Exception: the MariaDB vendored trees MUST ship their generated headers
# (my_config.h, mysql_version.h with MARIADB_BASE_VERSION, mysqld_error.h, ...).
# Unlike MySQL, pinba's CMake never synthesises these for MariaDB, so an offline
# mock/Copr build needs them committed. They are stable on x86_64 Linux.
!vendor/mariadb-headers-*/builddir/
!vendor/mariadb-headers-*/builddir/**

# OS files
.DS_Store
Thumbs.db
