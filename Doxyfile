PROJECT_NAME           = "Pinba Engine"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "MySQL Storage Engine for PHP Performance Statistics"

OUTPUT_DIRECTORY       = docs/api
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
BUILTIN_STL_SUPPORT    = YES

USE_MDFILE_AS_MAINPAGE = README.md

INPUT                  = README.md \
                         src/ha_pinba.h src/pinba.h src/pinba_types.h \
                         src/pinba_limits.h src/threadpool.h \
                         docs/build.md docs/docker.md docs/releasing.md \
                         docs/roadmap.md
RECURSIVE              = NO
EXCLUDE_PATTERNS       = */xxhash* */protobuf-c* */pinba.pb-c*
FILE_PATTERNS          = *.h *.md
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_DYNAMIC_SECTIONS  = YES
HTML_EXTRA_STYLESHEET  = docs/doxygen-awesome-css/doxygen-awesome.css
HTML_COLORSTYLE        = LIGHT
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
MAX_DOT_GRAPH_DEPTH    = 3

WARN_IF_UNDOCUMENTED   = NO
QUIET                  = YES

SORT_MEMBER_DOCS       = NO
SHOW_USED_FILES        = NO
SHOW_FILES             = YES
SHOW_NAMESPACES        = NO
