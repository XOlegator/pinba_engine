# Каждая MySQL серия — отдельный бинарный пакет:

Package: pinba-engine-mysql-8.0
Architecture: any
Depends: ${shlibs:Depends}, ${misc:Depends}, mysql-server-8.0 | mysql-community-server-8.0
Recommends: mysql-client-8.0
Description: Pinba MySQL Storage Engine — compiled for MySQL 8.0
 Pinba is a MySQL storage engine acting as a realtime monitoring and
 statistics server for PHP applications. This package contains ha_pinba.so
 compiled against MySQL 8.0 server headers.
 .
 After installation, load the plugin in MySQL:
   INSTALL PLUGIN pinba SONAME 'ha_pinba.so';

Package: pinba-engine-mysql-8.4
Architecture: any
Depends: ${shlibs:Depends}, ${misc:Depends}, mysql-server-8.4 | mysql-community-server-8.4
Recommends: mysql-client-8.4
Description: Pinba MySQL Storage Engine — compiled for MySQL 8.4
 Pinba is a MySQL storage engine acting as a realtime monitoring and
 statistics server for PHP applications. This package contains ha_pinba.so
 compiled against MySQL 8.4 server headers.

--- debian/rules (упрощённо) ---

#!/usr/bin/make -f
%:
	dh $@

# Пример override для одной MySQL серии.
# В реальности — цикл или отдельные override для 8.0 и 8.4.

override_dh_auto_configure-indep: ;

override_dh_auto_configure:
	# Сборка для MySQL 8.0
	cmake -B build-mysql80 \
	  -DCMAKE_BUILD_TYPE=Release \
	  -DPINBA_MYSQL_SERIES=8.0 \
	  -DPINBA_MYSQL_SOURCE_DIR=$(CURDIR)/vendor/mysql-headers-8.0 \
	  -DPINBA_MYSQL_SOURCE_VERSION=8.0.46 \
	  -DPINBA_WITH_TESTS=OFF \
	  -DCMAKE_INSTALL_PREFIX=/usr
	# Сборка для MySQL 8.4
	cmake -B build-mysql84 \
	  -DCMAKE_BUILD_TYPE=Release \
	  -DPINBA_MYSQL_SERIES=8.4 \
	  -DPINBA_MYSQL_SOURCE_DIR=$(CURDIR)/vendor/mysql-headers-8.4 \
	  -DPINBA_MYSQL_SOURCE_VERSION=8.4.9 \
	  -DPINBA_WITH_TESTS=OFF \
	  -DCMAKE_INSTALL_PREFIX=/usr

override_dh_auto_build:
	cmake --build build-mysql80 --parallel $(nproc)
	cmake --build build-mysql84 --parallel $(nproc)

override_dh_auto_install:
	DESTDIR=$(CURDIR)/debian/pinba-engine-mysql-8.0 \
	  cmake --install build-mysql80
	DESTDIR=$(CURDIR)/debian/pinba-engine-mysql-8.4 \
	  cmake --install build-mysql84

--- debian/pinba-engine-mysql-8.0.install ---

usr/lib/*/mysql/plugin/ha_pinba.so
usr/share/pinba_engine/

--- debian/pinba-engine-mysql-8.0.postinst ---

#!/bin/sh
set -e
PLUGIN_DIR=$(mysql_config --plugindir 2>/dev/null || echo /usr/lib/mysql/plugin)

case "$1" in
  configure)
    # Пытаемся установить плагин автоматически (только если сокет доступен)
    if mysql --no-defaults -u root -S /var/run/mysqld/mysqld.sock \
         -e "SELECT 1" >/dev/null 2>&1; then
      mysql --no-defaults -u root -S /var/run/mysqld/mysqld.sock \
        -e "INSTALL PLUGIN IF NOT EXISTS pinba SONAME 'ha_pinba.so';" \
        2>/dev/null && echo "pinba-engine: plugin installed in MySQL" || true
    else
      echo "------------------------------------------------------"
      echo "pinba-engine: MySQL not running or no root socket access."
      echo "To activate the plugin manually, run in MySQL:"
      echo "  INSTALL PLUGIN pinba SONAME 'ha_pinba.so';"
      echo "Then create the default tables:"
      echo "  SOURCE /usr/share/pinba_engine/default_tables.sql"
      echo "------------------------------------------------------"
    fi
    ;;
esac
exit 0

--- debian/pinba-engine-mysql-8.0.prerm ---

#!/bin/sh
set -e
case "$1" in
  remove|purge)
    if mysql --no-defaults -u root -S /var/run/mysqld/mysqld.sock \
         -e "SELECT 1" >/dev/null 2>&1; then
      mysql --no-defaults -u root -S /var/run/mysqld/mysqld.sock \
        -e "UNINSTALL PLUGIN IF EXISTS pinba;" 2>/dev/null || true
    else
      echo "pinba-engine: To unload the plugin manually:"
      echo "  UNINSTALL PLUGIN pinba;"
    fi
    ;;
esac
exit 0

